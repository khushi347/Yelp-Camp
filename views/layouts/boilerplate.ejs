<!DOCTYPE html>
<html lang="en">
<head>
  
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YelpCamp - Find Your Perfect Campground</title>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS (optional) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Leaflet CSS (for maps) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css">
    
    <!-- Main CSS - ALWAYS LOADED -->
    <link rel="stylesheet" href="/stylesheets/main.css">
    
    <!-- Page Specific CSS -->
    <% if (typeof stylesheet !== 'undefined') { %>
        <link rel="stylesheet" href="/stylesheets/<%= stylesheet %>">
    <% } %>
    
    <style>
        /* Ensure main.css is actually loaded - temporary debug */
        .navbar { display: flex; } /* This should be in main.css */
    </style>
</head>
<body>
    <!-- Navbar -->
    <%- include('../partials/navbar') %>

    <!-- Flash Messages -->
    <%- include('../partials/flash') %>

    <!-- Main Content -->
    <main class="<%= typeof fullWidth !== 'undefined' && fullWidth ? '' : 'container' %>">
        <%- body %>
    </main>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
    
    <!-- Main JS - ALWAYS LOADED -->
    <script src="/javascripts/main.js"></script>
    
    <!-- Page Specific JS -->
    <% if (typeof script !== 'undefined') { %>
        <script src="/javascripts/<%= script %>"></script>
    <% } %>
    
    <!-- Map Scripts (conditional) -->
    <% if (typeof clusterMap !== 'undefined' && clusterMap) { %>
        <script src="/javascripts/clusterMap.js"></script>
    <% } %>
    <% if (typeof showMap !== 'undefined' && showMap) { %>
        <script src="/javascripts/showMap.js"></script>
    <% } %>
    <% if (typeof editMap !== 'undefined' && editMap) { %>
        <script src="/javascripts/editMap.js"></script>
    <% } %>
    <% if (typeof newMap !== 'undefined' && newMap) { %>
        <script src="/javascripts/newCampground.js"></script>
    <% } %>
</body>
</html>